Host github.com-personal
  HostName github.com
  User git
  IdentityFile ~/.ssh/Personal
  IdentitiesOnly yes
  AddKeysToAgent yes
  UseKeychain yes

Host github.com
  HostName github.com
  User git
  IdentityFile ~/.ssh/Work
  IdentitiesOnly yes
  AddKeysToAgent yes
  UseKeychain yes

Host *
  AddKeysToAgent yes
  UseKeychain yes
  IdentitiesOnly yes
