#!/usr/bin/bash

send_notification() {
  volume=$(pamixer --get-volume)
  notify-send -a "changevolume" -u low -h string:x-canonical-private-synchronous:volume -h int:value:"$volume" -t 2000 "Volume" "${volume}%"
}

case $1 in
up)
  pamixer -u
  pamixer -i 5
  send_notification "$1"
  ;;
down)
  pamixer -u
  pamixer -d 5
  send_notification "$1"
  ;;
mute)
  pamixer -t
  if eval "$(pamixer --get-mute)"; then
    notify-send -a "changevolume" -u low -h string:x-canonical-private-synchronous:volume -t 2000 "Volume" "Muted"
  else
    send_notification up
  fi
  ;;
esac
